# OneChat client environment (Sprint 1).
# Copy this file to `client/.env` and fill in your Supabase project values.
# These are PUBLIC (EXPO_PUBLIC_*) and safe to ship — row-level security gates
# the anon key. Never put service-role keys or connector secrets in here.

# Project URL, e.g. https://abcdefghijklmnop.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# Project anon/public key (Settings -> API -> Project API keys -> anon public)
EXPO_PUBLIC_SUPABASE_ANON_KEY=
